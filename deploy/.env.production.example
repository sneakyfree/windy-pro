# Windy Pro — Production Environment Variables
# Copy to .env.production and fill in all values.
# Or run: ./scripts/init-production.sh to auto-generate secrets.
#
# Generate secrets: openssl rand -hex 32

# ─── Core Secrets (REQUIRED) ─────────────────────────────────────
# JWT signing secret for HS256 tokens. Must be at least 32 bytes hex.
JWT_SECRET=

# PostgreSQL password for the windy user.
POSTGRES_PASSWORD=

# ─── OIDC / OAuth2 ──────────────────────────────────────────────
# Public issuer URL for OIDC discovery. Must match the domain users access.
OIDC_ISSUER=https://windyword.ai

# ─── Stripe (Billing) ───────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Unified Windy Identity ─────────────────────────────────────
# HMAC-SHA256 secret for verifying Eternitas webhook signatures.
ETERNITAS_WEBHOOK_SECRET=

# ─── Synapse Matrix Homeserver ───────────────────────────────────
# Registration shared secret for admin API provisioning.
SYNAPSE_REGISTRATION_SECRET=
# Matrix server name (appears in @user:server.name).
SYNAPSE_SERVER_NAME=chat.windyword.ai

# ─── Chat Onboarding (Twilio + SendGrid) ────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
SENDGRID_API_KEY=

# ─── Cloud Storage (Cloudflare R2) ──────────────────────────────
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=windy-chat-backups

# ─── Push Notifications ─────────────────────────────────────────
# Firebase Cloud Messaging service account JSON (base64-encoded).
FCM_SERVICE_ACCOUNT=
# Apple Push Notification Service key.
APNS_KEY_ID=
APNS_TEAM_ID=
