# ─── Windy Chat Services — Environment Variables ───
# Copy to .env.chat and fill in values

# ── Shared ──
WINDY_JWT_SECRET=your-jwt-secret-here

# ── K2: Chat Onboarding (port 8101) ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@windypro.com

# ── K1/K2: Synapse Integration ──
SYNAPSE_URL=http://synapse:8008
SYNAPSE_ADMIN_URL=http://synapse:8008/_synapse/admin
SYNAPSE_REGISTRATION_SECRET=your-synapse-shared-secret
SYNAPSE_SERVER_NAME=chat.windypro.com

# ── K6: Push Gateway (port 8103) ──
FIREBASE_SERVICE_ACCOUNT=
APNS_KEY_PATH=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.windypro.chat

# ── K8: Backup (port 8104) ──
R2_BUCKET=windy-chat-backups
R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
