# Windy Pro Cloud — Environment Variables
# Copy this file to .env and fill in values before running docker-compose.
#
# Generate secrets with: python -c "import secrets; print(secrets.token_hex(32))"

# ─── Core ─────────────────────────────────────────────────────
WINDY_JWT_SECRET=
POSTGRES_PASSWORD=
WINDY_API_KEY=
WINDY_CORS_ORIGINS=https://windypro.com

# ─── Stripe (Billing) ────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Unified Windy Identity (Phase 10.0) ─────────────────────
# Eternitas webhook signature verification secret (HMAC-SHA256)
ETERNITAS_WEBHOOK_SECRET=

# ─── Synapse Matrix Homeserver (Strand K) ─────────────────────
SYNAPSE_DB_PASSWORD=
SYNAPSE_REGISTRATION_SECRET=
SYNAPSE_SERVER_NAME=chat.windypro.com

# ─── Chat Onboarding (Strand K2) ─────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@windypro.com

# ─── Cloud Storage (R2) ──────────────────────────────────────
R2_ACCOUNT_ID=
R2_BUCKET=windypro-storage
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
WINDY_ADMIN_SECRET=
