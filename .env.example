# ═══════════════════════════════════════════════════════
#  Windy Pro — Environment Variables
#  Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════

# ─── Server ───
# Port the account server listens on
PORT=8098

# Environment: "development" or "production"
NODE_ENV=development

# ─── Authentication ───
# JWT signing secret — MUST be at least 32 characters, random
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Token expiry (default: 24h)
JWT_EXPIRY=24h

# Maximum devices per account
MAX_DEVICES=5

# ─── Database ───
# Path to SQLite database file (created automatically)
DATABASE_PATH=./accounts.db

# ─── Stripe (Billing) ───
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Webhook signing secret from Stripe Dashboard → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# Price IDs from Stripe Dashboard → Products
STRIPE_PRO_PRICE_ID=price_your_pro_plan_price_id
STRIPE_TRANSLATE_PRICE_ID=price_your_translate_plan_price_id
STRIPE_TRANSLATE_PRO_PRICE_ID=price_your_translate_pro_price_id

# ─── AI / Translation APIs ───
# Deepgram — Speech-to-text (https://console.deepgram.com)
DEEPGRAM_API_KEY=dg_your_deepgram_api_key

# Groq — Fast inference (https://console.groq.com)
GROQ_API_KEY=gsk_your_groq_api_key

# OpenAI — Fallback translation + embeddings (https://platform.openai.com)
OPENAI_API_KEY=sk-your_openai_api_key

# ─── Python Transcription Backend ───
# Host and port for the FastAPI transcription service
TRANSCRIPTION_HOST=localhost
TRANSCRIPTION_PORT=9123

# Whisper model size: tiny, base, small, medium, large-v3
WHISPER_MODEL=base

# ─── Desktop App (Electron) ───
# Account server URL the desktop app connects to
ACCOUNT_SERVER_URL=http://localhost:8098

# Auto-update feed URL (electron-updater)
UPDATE_SERVER_URL=https://windypro.thewindstorm.uk/updates

# ─── Web Portal ───
# Vite dev server port
VITE_PORT=5173

# API base URL for the web frontend
VITE_API_BASE_URL=http://localhost:8098

# ─── Production ───
# Domain for the web portal
DOMAIN=windypro.thewindstorm.uk

# SSL certificate paths (for nginx or direct)
SSL_CERT_PATH=/etc/letsencrypt/live/windypro.thewindstorm.uk/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/windypro.thewindstorm.uk/privkey.pem

# ─── Rate Limiting ───
# Max requests per window
RATE_LIMIT_MAX=100

# Window duration in minutes
RATE_LIMIT_WINDOW_MINUTES=15

# ─── Storage ───
# Max upload size for video bundles (in bytes, default: 500MB)
MAX_UPLOAD_SIZE=524288000

# Local bundle storage directory (desktop)
BUNDLE_STORAGE_DIR=~/.config/windy-pro/clone-bundles

# ─── Logging ───
# Log level: error, warn, info, debug
LOG_LEVEL=info
