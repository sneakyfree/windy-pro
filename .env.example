# ══════════════════════════════════════════════════════════
# Windy Pro — Environment Variables
# Copy to .env and fill in your values
# ══════════════════════════════════════════════════════════

# ── Authentication & Security ─────────────────────────────
# JWT secret for signing auth tokens (min 32 chars, random)
WINDY_JWT_SECRET=change-me-to-a-random-64-char-string

# ── API Keys ──────────────────────────────────────────────
# Deepgram API key for cloud transcription (https://console.deepgram.com)
DEEPGRAM_API_KEY=

# Groq API key for fast LLM inference (https://console.groq.com)
GROQ_API_KEY=

# OpenAI API key for GPT-based features (https://platform.openai.com)
OPENAI_API_KEY=

# Windy Pro internal API key for service-to-service auth
WINDY_API_KEY=

# ── Stripe Payments ───────────────────────────────────────
# Stripe secret key (sk_live_... or sk_test_...)
STRIPE_SECRET_KEY=

# Stripe publishable key (pk_live_... or pk_test_...)
STRIPE_PUBLIC_KEY=

# Stripe webhook secret (whsec_...)
STRIPE_WEBHOOK_SECRET=

# ── Database ──────────────────────────────────────────────
# PostgreSQL password (used by docker-compose)
POSTGRES_PASSWORD=change-me

# Account server database path (SQLite, local dev)
DATABASE_PATH=./data/accounts.db

# ── Services ──────────────────────────────────────────────
# Account server port
ACCOUNT_SERVER_PORT=8098

# Transcription API port
TRANSCRIPTION_PORT=8000

# Web frontend port
WEB_PORT=3000

# Redis URL (for rate limiting and session cache)
REDIS_URL=redis://localhost:6379/0

# ── Cloud Storage ─────────────────────────────────────────
# S3-compatible storage for recordings (optional)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ── Deployment ────────────────────────────────────────────
# Production domain
DOMAIN=windypro.thewindstorm.uk

# Node environment (development | production)
NODE_ENV=development

# ── Electron Desktop ──────────────────────────────────────
# GitHub token for auto-update releases
GH_TOKEN=

# Sentry DSN for crash reporting (optional)
SENTRY_DSN=
