# ═══════════════════════════════════════════════════════════════
#  Windy Pro — Production .env template
#
#  Copy this file to `.env.production` (NOT committed, chmod 600)
#  and fill in every value marked "REQUIRED". Commented-out blocks
#  are optional — leave them commented to fall back to defaults.
#
#  Full descriptions live in DEPLOY.md § Environment variables.
# ═══════════════════════════════════════════════════════════════


# ═══════════════════════════════════════════════════════════════
#  1. IDENTITY / AUTH — hard-fails in prod if unset
# ═══════════════════════════════════════════════════════════════

NODE_ENV=production
PORT=8098

# HS256 fallback secret. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-me-with-64-random-hex-bytes

# RS256 keys — paths INSIDE the container (compose bind-mounts
# /var/lib/windypro/keys → /keys). Generate with:
#   openssl genrsa -out /var/lib/windypro/keys/private.pem 4096
#   openssl rsa -in /var/lib/windypro/keys/private.pem -pubout \
#          -out /var/lib/windypro/keys/public.pem
JWT_PRIVATE_KEY_PATH=/keys/private.pem
JWT_PUBLIC_KEY_PATH=/keys/public.pem
JWT_KEY_ID=windypro-prod-2026-04

# Canonical issuer — stamped into every JWT + OIDC metadata.
OIDC_ISSUER=https://windyword.ai

# CORS — comma-separated; the server hard-fails in prod if unset.
CORS_ALLOWED_ORIGINS=https://windyword.ai,https://windyword.ai,https://windyword.ai

# Trust exactly one proxy hop (the Nginx in front). Hard-fails if unset in prod.
TRUST_PROXY=1

# Device cap + short-lived token expiry.
MAX_DEVICES=5
JWT_EXPIRY=15m


# ═══════════════════════════════════════════════════════════════
#  2. INFRASTRUCTURE — Postgres, Redis, R2
# ═══════════════════════════════════════════════════════════════

# Postgres URL consumed by the account-server container. The compose
# file launches the Postgres service with POSTGRES_PASSWORD, so these
# two must agree.
POSTGRES_PASSWORD=replace-with-strong-generated-postgres-password
DATABASE_URL=postgres://windy:replace-with-strong-generated-postgres-password@postgres:5432/windy_identity

# Redis — rate-limit + token-blacklist backing store. Unset falls back
# to in-memory, which silently breaks multi-instance deploys.
REDIS_URL=redis://redis:6379

# On-disk upload root inside the container. Bind-mounted from
# /var/lib/windypro/uploads on the host.
DATA_ROOT=/data

# Cloudflare R2 for cold-storage recordings + exports.
R2_ACCOUNT_ID=replace-with-cloudflare-account-id
R2_ACCESS_KEY_ID=replace-with-r2-access-key-id
R2_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key
R2_BUCKET=windypro-uploads
R2_PUBLIC_URL=https://cdn.windyword.ai


# ═══════════════════════════════════════════════════════════════
#  3. BILLING — Stripe
# ═══════════════════════════════════════════════════════════════

STRIPE_SECRET_KEY=sk_live_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRO_PRICE_ID=price_replace_me
STRIPE_TRANSLATE_PRICE_ID=price_replace_me
STRIPE_TRANSLATE_PRO_PRICE_ID=price_replace_me


# ═══════════════════════════════════════════════════════════════
#  4. OUTBOUND MAIL — SMTP
# ═══════════════════════════════════════════════════════════════
#
# Used for password-reset + email-verification. Mail inbox
# provisioning for users/agents goes through the Windy Mail service,
# NOT these SMTP creds.

SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=SG.replace-with-sendgrid-api-key
SMTP_FROM=noreply@windyword.ai


# ═══════════════════════════════════════════════════════════════
#  5. LLM PROVIDER KEYS — managed-credential broker
# ═══════════════════════════════════════════════════════════════
#
# The broker holds these centrally and mints short-lived broker
# tokens for agents. The agent NEVER sees the raw values.
# Unset keys fall out of rotation for the tier they'd normally route
# to — leave them blank to disable that tier's LLM rather than 500ing
# on every request.

OPENAI_KEY=sk-replace-with-openai-key
ANTHROPIC_KEY=sk-ant-replace-with-anthropic-key
GEMINI_KEY=AIzaSy-replace-with-google-ai-studio-key


# ═══════════════════════════════════════════════════════════════
#  6. ECOSYSTEM WEBHOOK SHARED SECRETS
# ═══════════════════════════════════════════════════════════════
#
# Generate each independently:  openssl rand -hex 32
# Every inbound webhook is HMAC-verified; every outbound service
# call authenticates with the matching secret on the sister side.
# Rotate yearly or on suspected compromise — coordinate with the
# sister repo owner when you rotate.

ETERNITAS_WEBHOOK_SECRET=replace-with-32-random-hex-bytes
WINDYMAIL_SERVICE_TOKEN=replace-with-32-random-hex-bytes
CHAT_SERVICE_TOKEN=replace-with-32-random-hex-bytes
WINDY_CLOUD_SERVICE_TOKEN=replace-with-32-random-hex-bytes
SYNAPSE_REGISTRATION_SECRET=replace-with-32-random-hex-bytes

# Wave 8 broker HMAC — any agent host signing /credentials/issue
# requests uses this. Canonical body = python json.dumps(payload,
# separators=(",",":"),sort_keys=True). Headers: X-Windy-Signature
# (sha256=<hex>) + X-Windy-Timestamp.
BROKER_HMAC_SECRET=replace-with-32-random-hex-bytes

# Pro → windy-agent /hatch/remote.
WINDY_AGENT_SERVICE_TOKEN=replace-with-32-random-hex-bytes


# ═══════════════════════════════════════════════════════════════
#  7. ECOSYSTEM URLS + ETERNITAS CREDENTIALS
# ═══════════════════════════════════════════════════════════════

ETERNITAS_URL=https://eternitas.com
ETERNITAS_API_KEY=et_plt_replace_me
ETERNITAS_SERVICE_TOKEN=replace-with-eternitas-service-token

WINDYMAIL_API_URL=https://api.windymail.ai
WINDY_CHAT_URL=https://chat.windychat.ai
WINDY_CLOUD_URL=https://cloud.windycloud.com
WINDY_AGENT_URL=https://windyfly.ai

# Synapse (Matrix) — co-deployed with chat-onboarding in the compose
# stack. These must agree with synapse/homeserver.yaml.
SYNAPSE_URL=http://synapse:8008
SYNAPSE_SERVER_NAME=chat.windychat.ai


# ═══════════════════════════════════════════════════════════════
#  8. TWILIO — optional, only if SMS hatch ceremony is enabled
# ═══════════════════════════════════════════════════════════════

# TWILIO_ACCOUNT_SID=AC-replace-me
# TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
# TWILIO_MESSAGING_SID=MG-replace-me


# ═══════════════════════════════════════════════════════════════
#  9. OBSERVABILITY — optional
# ═══════════════════════════════════════════════════════════════
#
# Empty values disable these cleanly.

SENTRY_DSN=
GRAFANA_OTLP_ENDPOINT=


# ═══════════════════════════════════════════════════════════════
#  10. OAUTH PROVIDERS — "Sign in with X"
# ═══════════════════════════════════════════════════════════════
#
# Each provider's /api/v1/auth/oauth/<name>/* routes return 503 when its
# vars are unset. See account-server/docs/oauth-providers.md for the
# end-to-end provisioning runbook for GitHub, Apple, and Facebook.

# Google — already provisioned, see lockbox §"Windy Word OAuth (Web)".
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://account.windyword.ai/api/v1/auth/oauth/google/callback
GOOGLE_OAUTH_POST_LOGIN_REDIRECT=https://windyword.ai/auth/google/finish

# GitHub — provision OAuth App at https://github.com/settings/developers
# (sneakyfree account). Callback URL on GitHub must match the value below.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=https://account.windyword.ai/api/v1/auth/oauth/github/callback
GITHUB_OAUTH_POST_LOGIN_REDIRECT=https://windyword.ai/auth/oauth/finish

# Apple — Services ID + Sign-in-with-Apple key (.p8). See runbook for the
# 4-step Apple Developer portal provisioning. Team ID is fixed; Services ID
# + Key ID are minted per environment.
APPLE_TEAM_ID=VXZ434QL89
APPLE_SERVICES_ID=
APPLE_KEY_ID=
# Prefer path over inline for prod — keep the .p8 in /opt/windy-pro/secrets/.
APPLE_PRIVATE_KEY_PATH=
APPLE_OAUTH_REDIRECT_URI=https://account.windyword.ai/api/v1/auth/oauth/apple/callback
APPLE_OAUTH_POST_LOGIN_REDIRECT=https://windyword.ai/auth/oauth/finish
# Apple Services ID domain-verification string. Apple shows this in the
# portal modal when you click Verify on account.windyword.ai. Served from
# /.well-known/apple-developer-domain-association.txt — 404 until set.
APPLE_DOMAIN_ASSOCIATION=

# Facebook — provision App at https://developers.facebook.com. Email
# permission requires App Review before serving prod traffic.
FACEBOOK_OAUTH_CLIENT_ID=
FACEBOOK_OAUTH_CLIENT_SECRET=
FACEBOOK_OAUTH_REDIRECT_URI=https://account.windyword.ai/api/v1/auth/oauth/facebook/callback
FACEBOOK_OAUTH_POST_LOGIN_REDIRECT=https://windyword.ai/auth/oauth/finish
