# ════════════════════════════════════════════════════════════════════════════
#  Windy Pro — Account Server Environment Variables
# ════════════════════════════════════════════════════════════════════════════
#
# Copy this file to `.env` and fill in real values for the vars you need.
# Groups below are ordered roughly by "what breaks if you miss this":
#   §1 + §2 = server refuses to boot in production if unset
#   §3      = MFA data will be unrecoverable if you forget and later rotate
#   §4–§8   = features silently degrade or go offline
#   §9      = local-dev conveniences
#
# The codebase references 53 env vars (grep `process.env.` in src/). Every
# one is documented here. See docs/GAP_ANALYSIS.md for which ones cause
# specific production failures.


# ─── §1 Required — server hard-fails in production if missing ───────────────

# JWT signing secret. In production MUST be set (random 64-char hex).
# In dev, auto-generated at boot (ephemeral — tokens die on restart).
JWT_SECRET=your-secret-here

# Proxy trust level for req.ip / X-Forwarded-For. Required in production;
# defaults to `loopback` in dev. Behind a single AWS ALB set "1". Behind
# two hops (CloudFront → ALB) set "2". Or a comma-separated CIDR list.
# WITHOUT this, rate-limiting uses the LB's IP in prod and becomes a
# global cap shared across every user (Wave 7 P0-1).
TRUST_PROXY=

# Comma-separated allow-list of origins for CORS. Required in production.
# Without it, `origin: true` reflects any origin — CSRF risk if any
# cookie-authed flow is ever added (Wave 7 P0-7).
CORS_ALLOWED_ORIGINS=


# ─── §2 Required — silent unsafe defaults without these ─────────────────────

# AES-256-GCM key for encrypting MFA TOTP secrets at rest. 32 bytes hex
# (64 chars). If unset, the server derives it from JWT_SECRET via SHA-256
# and WARNS — meaning rotating JWT_SECRET later bricks every enrolled
# user's MFA. Set this explicitly in production (Wave 7 P1-1).
# Generate:  openssl rand -hex 32
MFA_ENCRYPTION_KEY=

# Shared secret Synapse uses when calling back to /api/v1/auth/chat-validate.
# If unset, chat-validate fails-closed (403) — Matrix bridge stops working.
SYNAPSE_REGISTRATION_SECRET=


# ─── §3 Webhook fan-out — one secret per consumer ───────────────────────────
#
# Per-consumer HMAC secrets. Set ALL of them in prod so the producer signs
# identity.created / identity.updated / identity.revoked events. See
# deploy/docs/webhook-env-vars.md for the minting + rotation procedure.
# Generate each:  openssl rand -hex 32

WINDY_MAIL_URL=
WINDY_MAIL_WEBHOOK_SECRET=

WINDY_CHAT_URL=
WINDY_CHAT_WEBHOOK_SECRET=

# Dev-only stub for /identity/chat/provision when the Chat backend is
# unreachable. Must be combined with NODE_ENV !== 'production' to
# activate (both conditions required, belt + suspenders). In prod the
# route returns 503 with a hint instead of faking success.
ALLOW_CHAT_STUB=

WINDY_CLOUD_URL=
WINDY_CLOUD_WEBHOOK_SECRET=

WINDY_CLONE_URL=
WINDY_CLONE_WEBHOOK_SECRET=

# INBOUND signature secret for the windy-connect orchestrator Worker's
# /v1/pair/verify callback to POST /api/v1/identity/connect/paired.
# When unset, the webhook fails-closed (503) and the dashboard tile
# stays "Available" — set this + WINDY_PRO_ACCOUNT_SERVER_URL on the
# Worker side (same value) to flip the tile to "Active" after pairing.
WINDY_CONNECT_WEBHOOK_SECRET=

ETERNITAS_URL=
# INBOUND signature secret for passport events from Eternitas.
# Since Wave 7 P0-2, the server fails-closed (503) if this is unset —
# no more silent skip of signature verification.
ETERNITAS_WEBHOOK_SECRET=

# INBOUND signature secret for the /webhooks/eternitas firehose
# (Wave 13). Separate from ETERNITAS_WEBHOOK_SECRET above: that one
# signs individual passport events for bots we operate locally; this
# one signs the ecosystem-wide firehose (operator.registered,
# clearance.promoted, trust.band_changed, etc.). Both secrets must
# be set in production. Fails-closed with 503 when unset.
# Shared with Eternitas side: key HMAC_WINDY_PRO in their state file.
ETERNITAS_HMAC_SECRET=


# ─── §4 Server / runtime ────────────────────────────────────────────────────

PORT=8098
NODE_ENV=development

# ─── §4.1 Deployment identity (MF1 contract for GET /version) ──────────
# Set by the build/deploy pipeline; leave blank in local dev.
# COMMIT_SHA: long-form git SHA the running container was built from
# BUILD_TIMESTAMP: ISO-8601 UTC of when the container image was built
# ENVIRONMENT: production | staging | development. Falls back to NODE_ENV
#   then 'unknown' if neither is set.
COMMIT_SHA=
BUILD_TIMESTAMP=
ENVIRONMENT=

# Node.js libuv thread pool size. Default 4. Bcrypt + crypto hashing + pg
# socket I/O + DNS all share this pool — on production bursts (20+
# concurrent signups) the default saturates and /health requests queue
# behind hashing work. Raise to 16 on prod EC2 to decouple auth hashing
# from the event loop. Runtime-only; no code reads it.
UV_THREADPOOL_SIZE=

# Overridden OIDC issuer (prod: https://account.windyword.ai).
# If unset, derived from request host headers.
OIDC_ISSUER=

# Override the data-root directory for uploads, etc. Default: ./data
DATA_ROOT=


# ─── §5 Database + cache ────────────────────────────────────────────────────

# Override the SQLite file location. Default = accounts.db next to the
# package. Used in tests and installers that need an isolated DB path.
# Ignored when DATABASE_URL is set (Postgres takes precedence).
DB_PATH=

# Use DATABASE_URL to opt into PostgreSQL instead (prod default).
DATABASE_URL=
# e.g. postgres://windy:password@rds.amazonaws.com:5432/windypro

# Postgres pool sizing (only used by the async adapter path — ignored on SQLite).
# Tunable without a redeploy so we can size the pool against real load.
PG_POOL_MAX=            # default 10 — max concurrent pg clients
PG_POOL_IDLE_MS=        # default 10000 — idle client timeout (ms)
PG_POOL_CONNECT_MS=     # default 2000 — connect timeout (ms)

# Test-only — integration tests use this to exercise the pooled async
# adapter against a live Postgres. Unset in dev and prod.
TEST_POSTGRES_URL=

# Redis for shared rate-limit/OTP/token-blacklist state across multiple tasks.
# Required in prod to make rate limits ACTUALLY share across ECS replicas.
REDIS_URL=
# e.g. redis://elasticache.amazonaws.com:6379/0


# ─── §6 RS256 key management (OIDC / JWKS) ──────────────────────────────────
#
# Production expects one of these so /.well-known/jwks.json returns
# non-empty keys. Without them, tokens sign with HS256 + JWT_SECRET and
# every ecosystem consumer that verifies via JWKS rejects everything
# (Wave 7 P0-4).

# Inline PEM of the RSA private key — simplest prod deploy. Accepts both
# standard multi-line PEM and "\n"-escaped single-line (as some secret
# stores return multi-line values). The Wave-4 AWS Terraform scaffold
# populates this from tls_private_key.jwt into Secrets Manager.
JWT_PRIVATE_KEY=

# Path to a PEM-encoded RSA private key file on disk.
JWT_PRIVATE_KEY_PATH=

# Directory for key rotation (multiple JSON files, each a ManagedKey).
JWKS_KEY_DIR=


# ─── §7 Email / SMS providers ───────────────────────────────────────────────

# Resend — transactional email (verification codes, password reset).
# If unset, the mailer logs to stdout instead of sending — useful for dev,
# catastrophic if you ship to production thinking emails flow.
RESEND_API_KEY=

# "From" address on outgoing mail. Default "Windy <noreply@windyword.ai>".
MAIL_FROM=

# URL base the password-reset email embeds — e.g. "https://windyword.ai/reset-password".
# If unset, emails include only the raw token for the user to paste.
PASSWORD_RESET_URL_BASE=

# Legacy SendGrid path (used by the pre-existing /identity/verify/* flow).
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Twilio for SMS verification (also the /identity/verify/* flow).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=


# ─── §8 Payments / billing (Stripe) ─────────────────────────────────────────

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PORTAL_RETURN_URL=


# ─── §9 Ecosystem service-to-service tokens ─────────────────────────────────

# Inbound webhook URLs some flows use (older than §3's signed fan-out).
WINDY_CHAT_WEBHOOK_URL=
WINDY_MAIL_WEBHOOK_URL=

# Service tokens for calls FROM account-server TO other services.
CHAT_SERVICE_TOKEN=
WINDY_CLOUD_SERVICE_TOKEN=
ETERNITAS_API_KEY=
ETERNITAS_SERVICE_TOKEN=

# Chat Matrix homeserver URLs.
SYNAPSE_URL=
SYNAPSE_ADMIN_URL=
SYNAPSE_SERVER_NAME=

# Windy Fly gateway (agent platform).
WINDYFLY_GATEWAY_URL=

# Alternate Mail API (bot API + inbox).
WINDYMAIL_API_URL=
WINDYMAIL_SERVICE_TOKEN=

# Base URL for callback webhooks sent TO our ecosystem consumers.
WEBHOOK_BASE_URL=

# Contact email surfaced when Pro registers itself as an Eternitas platform.
# Defaults to support@windyword.ai if unset.
PLATFORM_CONTACT_EMAIL=

# Windy Fly agent host — Pro → POST /hatch/remote during the Wave 8
# hatch ceremony. Service token authenticates the S2S call.
WINDY_AGENT_URL=
WINDY_AGENT_SERVICE_TOKEN=

# Wave 8 — HMAC secret for the managed-credential broker.
# Any agent host calling POST /api/v1/agent/credentials/issue signs
# with this using python json.dumps(payload, separators=(",",":"),
# sort_keys=True) and sends X-Windy-Signature: sha256=<hex> +
# X-Windy-Timestamp headers. Generate: openssl rand -hex 32.
BROKER_HMAC_SECRET=


# ─── §10 Storage (Cloudflare R2) ────────────────────────────────────────────

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_TIMEOUT_MS=


# ─── §11 LLM / transcription provider keys ─────────────────────────────────

GROQ_API_KEY=
OPENAI_API_KEY=

# Windy Mind broker (ADR-010 §8 BYOM). When set, /translate routes route
# authenticated LLM calls through Mind instead of direct Groq/OpenAI.
# Mind broker handles routing, EI-tier rate limits, and audit log.
MIND_API_URL=https://api.windymind.ai

# When true, anonymous /translate/text callers route through Mind via
# service token. Default false; reserved for Mind master plan M3+.
MIND_FORCE_FOR_ANONYMOUS=false
# Wave 8 — managed-credential broker. Provider keys the broker holds
# centrally; it mints short-lived bk_live_* tokens for agents instead
# of exposing the raw credential. Each has a legacy alias the config
# falls back to (OPENAI_API_KEY above still works).
# Plan-tier routing:
#   free        → GEMINI_KEY     (alias: GOOGLE_API_KEY)
#   starter     → OPENAI_KEY     (alias: OPENAI_API_KEY)
#   pro / ent.  → ANTHROPIC_KEY  (alias: ANTHROPIC_API_KEY)
OPENAI_KEY=
ANTHROPIC_KEY=
ANTHROPIC_API_KEY=
GEMINI_KEY=
GOOGLE_API_KEY=

# Windy Search — master plan §2 V1 hard gate. All 10 Windy products
# must call api.windysearch.com rather than direct Brave / Google
# bridges. The EPT is a service-account Eternitas Passport Token
# issued for account-server's platform_id. Preemptive wiring today:
# routes that grow a web-search surface (translate-with-citations,
# admin-console research, agent-host search proxy) pull the
# pre-configured client from `services/search/getWindySearchClient()`.
# Unset EPT → singleton returns null and callers 503 gracefully.
WINDY_SEARCH_BASE_URL=https://api.windysearch.com
WINDY_SEARCH_EPT=

# Google Cloud Vision OCR API key — used for handwriting/image text
# extraction. Optional; OCR endpoints fall back to 503 when unset.
GOOGLE_VISION_API_KEY=

# Firebase Cloud Messaging server key — used for push notifications from
# Windy Cloud. Optional; pushes silently no-op when unset.
FCM_SERVER_KEY=

# "Sign in with Google" — consumer-side OAuth credentials. Get these from
# the Google Cloud Console → APIs & Services → Credentials. Required for the
# /api/v1/auth/oauth/google/* routes; if any of the three are blank those
# routes return 503 and the SPA's "Continue with Google" button silently
# falls back to email/password. Lockbox: "Windy Word OAuth (Web)".
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Must exactly match an Authorized redirect URI configured on the Google
# Cloud OAuth client. Local dev: http://localhost:8098/api/v1/auth/oauth/google/callback
# Prod: https://account.windyword.ai/api/v1/auth/oauth/google/callback
GOOGLE_OAUTH_REDIRECT_URI=
# Where the SPA finish page lives. Tokens land in the URL fragment of this URL.
# Dev: http://localhost:5173/auth/google/finish
# Prod: https://windyword.ai/auth/google/finish
GOOGLE_OAUTH_POST_LOGIN_REDIRECT=

# "Sign in with GitHub" — consumer-side OAuth credentials. Provision the
# OAuth App at https://github.com/settings/developers (sneakyfree account).
# When unset the /api/v1/auth/oauth/github/* routes return 503 and the SPA
# button silently disables. Lockbox: "Windy Word GitHub OAuth" (add post-provision).
#   Callback URL on GitHub: https://account.windyword.ai/api/v1/auth/oauth/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=
# Dev: http://localhost:5173/auth/oauth/finish
# Prod: https://windyword.ai/auth/oauth/finish
GITHUB_OAUTH_POST_LOGIN_REDIRECT=

# "Sign in with Apple" — Services ID + Sign-in-with-Apple private key (.p8).
# Provision at developer.apple.com → Identifiers → Services IDs. The client
# secret is generated server-side as a short-lived ES256 JWT (no static
# client_secret env var; APPLE_PRIVATE_KEY is the .p8 contents).
#   Return URL on Apple: https://account.windyword.ai/api/v1/auth/oauth/apple/callback
APPLE_TEAM_ID=
APPLE_SERVICES_ID=
APPLE_KEY_ID=
# Either inline (literal \n) or via APPLE_PRIVATE_KEY_PATH (preferred for prod).
APPLE_PRIVATE_KEY=
APPLE_PRIVATE_KEY_PATH=
APPLE_OAUTH_REDIRECT_URI=
APPLE_OAUTH_POST_LOGIN_REDIRECT=
# Domain ownership verification string for Apple's Services ID config.
# Apple shows this in the portal modal when you click "Verify" on a domain;
# paste the raw string here, restart, then click Verify in the portal.
# Served at /.well-known/apple-developer-domain-association.txt
APPLE_DOMAIN_ASSOCIATION=

# "Sign in with Facebook" — consumer-side OAuth credentials. Provision the
# App at https://developers.facebook.com → My Apps. Email permission requires
# Facebook App Review before serving prod traffic past test users.
#   Callback URL on Facebook: https://account.windyword.ai/api/v1/auth/oauth/facebook/callback
FACEBOOK_OAUTH_CLIENT_ID=
FACEBOOK_OAUTH_CLIENT_SECRET=
FACEBOOK_OAUTH_REDIRECT_URI=
FACEBOOK_OAUTH_POST_LOGIN_REDIRECT=

# Cloud STT (AWS GPU instances for heavy transcription workloads).
AWS_STT_ENABLED=false
AWS_STT_ENDPOINT=

# AWS Transcribe Streaming (ADR-009 M1) — /ws/transcribe WebSocket proxy.
# Mints dedicated IAM user 'windy-transcribe-streaming' with
# transcribe:StartStreamTranscription only. See lockbox §"AWS Transcribe
# Streaming IAM" for canonical key. Without these set, /ws/transcribe
# accepts WS connections but warns at boot — no AWS calls fire.
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Alternatives to access-key auth — set ONE auth source (key, profile,
# or role). Boot-time detection in transcribe-stream.ts checks all three.
AWS_PROFILE=
AWS_ROLE_ARN=


# ─── §12 Observability ─────────────────────────────────────────────────────

# Sentry error reporting. Optional but recommended in production.
SENTRY_DSN=


# ─── §13 Admin bootstrap (Wave 14 P1-3) ─────────────────────────────────────
#
# If BOTH of these are set at startup, the server seeds an admin user
# with role='admin' on first boot. Idempotent: if any admin already
# exists, the bootstrap is a no-op. After first login, UNSET these
# from the environment and restart — leaving them set in prod means
# the password hash sits in the orchestrator's env forever.
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=


# ─── §14 Outbound email (Wave 14 P0-1 — reminder) ──────────────────────────
#
# RESEND_API_KEY is already declared in §7 above. The companion P0-1 PR
# (wave14/p0-forgot-token-leak, see server.ts NODE_ENV=production check)
# makes this key REQUIRED in production: boot fails if it's unset.
# Without it, /auth/forgot-password + email verification would "succeed"
# silently and users would never receive their reset links. Left as a
# cross-reference block so the prod-required contract is discoverable
# from this section of the template too.
