# ════════════════════════════════════════════════════════
#  Windy Pro — Account Server Environment Variables
# ════════════════════════════════════════════════════════

# ─── Required ─────────────────────────────────────────

# JWT signing secret — REQUIRED in production, auto-generated in dev
JWT_SECRET=your-secret-here

# ─── Server ───────────────────────────────────────────

PORT=8098
NODE_ENV=development

# ─── Database (Phase 7A) ─────────────────────────────

# SQLite (default — no configuration needed):
# DB_PATH=./accounts.db

# PostgreSQL (optional — set this to use PostgreSQL instead of SQLite):
# DATABASE_URL=postgres://windy:password@localhost:5432/windy_pro

# ─── Redis (Phase 7A) ────────────────────────────────

# In-memory (default — no configuration needed)
# Redis (optional — set this for shared OTP/blacklist/cache state):
# REDIS_URL=redis://localhost:6379/0

# ─── RS256 Key Management (Phase 4) ──────────────────

# Single key file:
# JWT_PRIVATE_KEY_PATH=./data/keys/jwt-private.pem

# Key rotation directory:
# JWKS_KEY_DIR=./data/keys

# ─── Stripe Billing ──────────────────────────────────

# Stripe API key and webhook secret
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — one-time (lifetime) prices
# STRIPE_PRO_PRICE_ID=price_...
# STRIPE_TRANSLATE_PRICE_ID=price_...
# STRIPE_TRANSLATE_PRO_PRICE_ID=price_...

# Stripe Price IDs — recurring (monthly) subscription prices
# STRIPE_PRO_MONTHLY_PRICE_ID=price_...
# STRIPE_TRANSLATE_MONTHLY_PRICE_ID=price_...
# STRIPE_TRANSLATE_PRO_MONTHLY_PRICE_ID=price_...

# Stripe Price IDs — recurring (yearly) subscription prices
# STRIPE_PRO_YEARLY_PRICE_ID=price_...
# STRIPE_TRANSLATE_YEARLY_PRICE_ID=price_...
# STRIPE_TRANSLATE_PRO_YEARLY_PRICE_ID=price_...

# Return URL after Stripe Checkout or Billing Portal
# STRIPE_PORTAL_RETURN_URL=https://windypro.thewindstorm.uk/dashboard

# ─── AI APIs ─────────────────────────────────────────

# GROQ_API_KEY=gsk_...
# OPENAI_API_KEY=sk-...

# ─── Verification (Twilio SMS + SendGrid Email) ──────

# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_PHONE_NUMBER=+1...

# SENDGRID_API_KEY=SG...
# SENDGRID_FROM_EMAIL=noreply@windypro.com

# ─── Matrix / Synapse (Chat) ─────────────────────────

# SYNAPSE_URL=http://localhost:8008
# SYNAPSE_ADMIN_URL=http://localhost:8008/_synapse/admin
# SYNAPSE_REGISTRATION_SECRET=...
# SYNAPSE_SERVER_NAME=chat.windypro.com

# ─── Eternitas Webhook ───────────────────────────────

# ETERNITAS_WEBHOOK_SECRET=...

# ─── Ecosystem Auto-Provisioning ─────────────────────

# Windy Mail provisioning (set when mail service is deployed)
WINDYMAIL_API_URL=http://localhost:8200
WINDYMAIL_SERVICE_TOKEN=change-me-shared-secret
# Chat provisioning is lazy (on first access via /identity/chat/provision)
# Cloud provisioning is local (storage_limit column)

# ─── OIDC ────────────────────────────────────────────

# OIDC_ISSUER=https://windypro.thewindstorm.uk
