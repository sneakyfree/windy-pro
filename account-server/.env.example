# ════════════════════════════════════════════════════════════════════════════
#  Windy Pro — Account Server Environment Variables
# ════════════════════════════════════════════════════════════════════════════
#
# Copy this file to `.env` and fill in real values for the vars you need.
# Groups below are ordered roughly by "what breaks if you miss this":
#   §1 + §2 = server refuses to boot in production if unset
#   §3      = MFA data will be unrecoverable if you forget and later rotate
#   §4–§8   = features silently degrade or go offline
#   §9      = local-dev conveniences
#
# The codebase references 53 env vars (grep `process.env.` in src/). Every
# one is documented here. See docs/GAP_ANALYSIS.md for which ones cause
# specific production failures.


# ─── §1 Required — server hard-fails in production if missing ───────────────

# JWT signing secret. In production MUST be set (random 64-char hex).
# In dev, auto-generated at boot (ephemeral — tokens die on restart).
JWT_SECRET=your-secret-here

# Proxy trust level for req.ip / X-Forwarded-For. Required in production;
# defaults to `loopback` in dev. Behind a single AWS ALB set "1". Behind
# two hops (CloudFront → ALB) set "2". Or a comma-separated CIDR list.
# WITHOUT this, rate-limiting uses the LB's IP in prod and becomes a
# global cap shared across every user (Wave 7 P0-1).
TRUST_PROXY=

# Comma-separated allow-list of origins for CORS. Required in production.
# Without it, `origin: true` reflects any origin — CSRF risk if any
# cookie-authed flow is ever added (Wave 7 P0-7).
CORS_ALLOWED_ORIGINS=


# ─── §2 Required — silent unsafe defaults without these ─────────────────────

# AES-256-GCM key for encrypting MFA TOTP secrets at rest. 32 bytes hex
# (64 chars). If unset, the server derives it from JWT_SECRET via SHA-256
# and WARNS — meaning rotating JWT_SECRET later bricks every enrolled
# user's MFA. Set this explicitly in production (Wave 7 P1-1).
# Generate:  openssl rand -hex 32
MFA_ENCRYPTION_KEY=

# Shared secret Synapse uses when calling back to /api/v1/auth/chat-validate.
# If unset, chat-validate fails-closed (403) — Matrix bridge stops working.
SYNAPSE_REGISTRATION_SECRET=


# ─── §3 Webhook fan-out — one secret per consumer ───────────────────────────
#
# Per-consumer HMAC secrets. Set ALL of them in prod so the producer signs
# identity.created / identity.updated / identity.revoked events. See
# deploy/docs/webhook-env-vars.md for the minting + rotation procedure.
# Generate each:  openssl rand -hex 32

WINDY_MAIL_URL=
WINDY_MAIL_WEBHOOK_SECRET=

WINDY_CHAT_URL=
WINDY_CHAT_WEBHOOK_SECRET=

WINDY_CLOUD_URL=
WINDY_CLOUD_WEBHOOK_SECRET=

WINDY_CLONE_URL=
WINDY_CLONE_WEBHOOK_SECRET=

ETERNITAS_URL=
# INBOUND signature secret for passport events from Eternitas.
# Since Wave 7 P0-2, the server fails-closed (503) if this is unset —
# no more silent skip of signature verification.
ETERNITAS_WEBHOOK_SECRET=


# ─── §4 Server / runtime ────────────────────────────────────────────────────

PORT=8098
NODE_ENV=development

# Overridden OIDC issuer (prod: https://api.windyword.ai).
# If unset, derived from request host headers.
OIDC_ISSUER=

# Override the data-root directory for uploads, etc. Default: ./data
DATA_ROOT=


# ─── §5 Database + cache ────────────────────────────────────────────────────

# SQLite path is hardcoded in config.ts to accounts.db next to the package.
# Use DATABASE_URL to opt into PostgreSQL instead (prod default).
DATABASE_URL=
# e.g. postgres://windy:password@rds.amazonaws.com:5432/windypro

# Redis for shared rate-limit/OTP/token-blacklist state across multiple tasks.
# Required in prod to make rate limits ACTUALLY share across ECS replicas.
REDIS_URL=
# e.g. redis://elasticache.amazonaws.com:6379/0


# ─── §6 RS256 key management (OIDC / JWKS) ──────────────────────────────────
#
# Production expects one of these so /.well-known/jwks.json returns
# non-empty keys. Without them, tokens sign with HS256 + JWT_SECRET and
# every ecosystem consumer that verifies via JWKS rejects everything
# (Wave 7 P0-4).

# Inline PEM of the RSA private key — simplest prod deploy. Accepts both
# standard multi-line PEM and "\n"-escaped single-line (as some secret
# stores return multi-line values). The Wave-4 AWS Terraform scaffold
# populates this from tls_private_key.jwt into Secrets Manager.
JWT_PRIVATE_KEY=

# Path to a PEM-encoded RSA private key file on disk.
JWT_PRIVATE_KEY_PATH=

# Directory for key rotation (multiple JSON files, each a ManagedKey).
JWKS_KEY_DIR=


# ─── §7 Email / SMS providers ───────────────────────────────────────────────

# Resend — transactional email (verification codes, password reset).
# If unset, the mailer logs to stdout instead of sending — useful for dev,
# catastrophic if you ship to production thinking emails flow.
RESEND_API_KEY=

# "From" address on outgoing mail. Default "Windy <noreply@windypro.com>".
MAIL_FROM=

# URL base the password-reset email embeds — e.g. "https://windyword.ai/reset-password".
# If unset, emails include only the raw token for the user to paste.
PASSWORD_RESET_URL_BASE=

# Legacy SendGrid path (used by the pre-existing /identity/verify/* flow).
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Twilio for SMS verification (also the /identity/verify/* flow).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=


# ─── §8 Payments / billing (Stripe) ─────────────────────────────────────────

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PORTAL_RETURN_URL=


# ─── §9 Ecosystem service-to-service tokens ─────────────────────────────────

# Inbound webhook URLs some flows use (older than §3's signed fan-out).
WINDY_CHAT_WEBHOOK_URL=
WINDY_MAIL_WEBHOOK_URL=

# Service tokens for calls FROM account-server TO other services.
CHAT_SERVICE_TOKEN=
WINDY_CLOUD_SERVICE_TOKEN=
ETERNITAS_API_KEY=
ETERNITAS_SERVICE_TOKEN=

# Chat Matrix homeserver URLs.
SYNAPSE_URL=
SYNAPSE_ADMIN_URL=
SYNAPSE_SERVER_NAME=

# Windy Fly gateway (agent platform).
WINDYFLY_GATEWAY_URL=

# Alternate Mail API (bot API + inbox).
WINDYMAIL_API_URL=
WINDYMAIL_SERVICE_TOKEN=

# Base URL for callback webhooks sent TO our ecosystem consumers.
WEBHOOK_BASE_URL=


# ─── §10 Storage (Cloudflare R2) ────────────────────────────────────────────

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_TIMEOUT_MS=


# ─── §11 LLM / transcription provider keys ─────────────────────────────────

GROQ_API_KEY=
OPENAI_API_KEY=

# Cloud STT (AWS GPU instances for heavy transcription workloads).
AWS_STT_ENABLED=false
AWS_STT_ENDPOINT=


# ─── §12 Observability ─────────────────────────────────────────────────────

# Sentry error reporting. Optional but recommended in production.
SENTRY_DSN=
