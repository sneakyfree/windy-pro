{
  "name": "windy-pro",
  "version": "1.6.1",
  "description": "Voice-to-text desktop app powered by the Windy Pro Engine",
  "main": "src/client/desktop/main.js",
  "author": {
    "name": "Windy Pro",
    "email": "dev@windyword.ai"
  },
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "install:web": "cd src/client/web && npm install",
    "build:web": "cd src/client/web && npm install && npm run build",
    "server": "python -m src.engine.server",
    "test": "python3 -m pytest tests/ -v --ignore=tests/test_cloud_api.py",
    "test:api": "cd account-server && npx jest tests/api.test.ts --forceExit",
    "dist:all": "npm run build:linux && npm run build:win && npm run build:mac",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "archiver": "^7.0.0",
    "better-sqlite3": "^11.0.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.0",
    "form-data": "^4.0.5",
    "matrix-js-sdk": "^41.1.0",
    "node-fetch": "^2.7.0",
    "stripe": "^20.4.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "playwright": "^1.59.1"
  },
  "build": {
    "appId": "pro.windy.app",
    "extraResources": [
      {
        "from": "src/engine",
        "to": "engine",
        "filter": [
          "**/*.py",
          "requirements.txt"
        ]
      },
      {
        "from": "installer-v2",
        "to": "installer-v2"
      },
      {
        "from": "extraResources/",
        "to": "bundled",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "scripts/linux/install-windy-pro.sh",
        "to": "install-windy-pro.sh"
      },
      {
        "from": "shared/",
        "to": "shared",
        "filter": [
          "**/*"
        ]
      }
    ],
    "productName": "Windy Pro",
    "directories": {
      "output": "dist"
    },
    "protocols": [
      {
        "name": "Windy Pro Deep Links",
        "schemes": [
          "windypro",
          "windychat",
          "windyword",
          "windyfly"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "sneakyfree",
        "repo": "windy-pro"
      }
    ],
    "files": [
      "src/**/*",
      "installer-v2/**/*",
      "!**/*.pyc",
      "!**/__pycache__"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "identity": null,
      "notarize": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Windy Pro needs microphone access for voice-to-text transcription.",
        "NSCameraUsageDescription": "Windy Pro needs camera access for the video preview feature."
      }
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico",
      "sign": null,
      "signingHashAlgorithms": null
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icon.png",
      "category": "Utility",
      "maintainer": "Windy Pro <dev@windyword.ai>",
      "executableName": "windy-pro",
      "desktop": {
        "Name": "Windy Pro",
        "Comment": "Voice-to-text transcription",
        "Terminal": "false",
        "Type": "Application",
        "Categories": "Utility;Audio;Accessibility;",
        "StartupWMClass": "windy-pro",
        "MimeType": ""
      }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh"
    },
    "deb": {
      "depends": [],
      "afterInstall": "scripts/linux/postinst",
      "afterRemove": "scripts/linux/postrm",
      "fpm": [
        "--before-install",
        "scripts/linux/preinst",
        "--before-remove",
        "scripts/linux/prerm"
      ]
    }
  }
}
